{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/isletmeler/layout,_N_T_/isletmeler/page,_N_T_/isletmeler"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/isletmeler/__PAGE__",
    "/isletmeler",
    "/_index",
    "/_head"
  ]
}